# Schwerzenbach räumt aus — Backend-Konfiguration
# Kopieren nach backend/config/.env und Werte anpassen (NICHT versionieren).

# --- Datenbank (MySQL/MariaDB) ---
DB_HOST=localhost
DB_PORT=3306
DB_NAME=schwerzenbach_raeumt_aus
DB_USER=root
DB_PASS=

# --- App ---
# Basis-URL der Anwendung (für Links in E-Mails, z. B. den Bearbeitungs-Link)
APP_BASE_URL=https://schwerzenbach-raeumt-aus.ch
# Umgebung: dev | prod  (dev liefert ausführlichere Fehlermeldungen)
APP_ENV=dev

# --- E-Mail (PHPMailer / SMTP, hoststar) ---
MAIL_FROM=noreply@schwerzenbach-raeumt-aus.ch
MAIL_FROM_NAME=Schwerzenbach räumt aus
MAIL_TRANSPORT=mail        # mail | smtp
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=tls            # tls | ssl | (leer)

# --- Sicherheit ---
# Erlaubte Anmeldungen pro IP pro Stunde (Rate-Limit)
RATE_LIMIT_PER_HOUR=10
